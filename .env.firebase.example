# Copy this file to `.env.firebase` and fill in real values.
# Keep the resulting `.env.firebase` file out of version control.

# Firebase project and app identity from Project Settings -> General.
FIREBASE_PROJECT_ID=en-practice
FIREBASE_APP_ID_ANDROID=1:236428171454:android:1c838c4855d3f5146c66ef
FIREBASE_APP_ID_IOS=1:236428171454:ios:328d29c475e023416c66ef

# Optional CLI auth if you do not want to rely on `firebase login`.
# Use a service account with the Firebase App Distribution Admin role.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-app-distribution-service-account.json

# Optional alternative CLI auth for CI.
FIREBASE_TOKEN=

# Optional distribution targeting.
FIREBASE_TESTERS=
FIREBASE_TESTERS_FILE=
FIREBASE_TESTER_GROUPS=
FIREBASE_GROUPS_FILE=

# Optional release notes file. A default template is committed in the repo.
FIREBASE_RELEASE_NOTES_FILE=config/firebase/app_distribution/release_notes.txt

# iOS-only default for `flutter build ipa`.
IOS_EXPORT_METHOD=ad-hoc
